# Vellum package recipe for rm-wiki.
# Copy this directory into vellum-dev/vellum/packages/rm-wiki for submission.

pkgname=rm-wiki
pkgver=0.1.0
pkgrel=0
pkgdesc="Paged Wikipedia reader for reMarkable Paper Pro and Paper Pro Move"
url="https://github.com/avenarius-argus/rm-wiki"
arch="noarch"
license="MIT"
depends="appload !rm1 !rm2"
options="!check !fhs !strip !tracedeps"

source="
$url/releases/download/v$pkgver/$pkgname-$pkgver-appload.tar.gz
https://raw.githubusercontent.com/avenarius-argus/rm-wiki/v$pkgver/LICENSE
"

package() {
    install -dm755 "$pkgdir/home/root/xovi/exthome/appload"
    cp -r "$srcdir/$pkgname" "$pkgdir/home/root/xovi/exthome/appload/$pkgname"

    install -Dm644 "$srcdir"/LICENSE \
        "$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE
    echo "$url" > "$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

