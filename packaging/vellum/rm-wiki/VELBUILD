# Vellum package recipe for rm-wiki.
# Copy this directory into vellum-dev/vellum/packages/rm-wiki for submission.

pkgname=rm-wiki
pkgver=0.1.0
pkgrel=0
pkgdesc="Paged Wikipedia reader for reMarkable Paper Pro and Paper Pro Move"
url="https://github.com/avenarius-argus/rm-wiki"
arch="noarch"
license="MIT"
depends="appload !rm1 !rm2"
source="$url/releases/download/v$pkgver/$pkgname-$pkgver-appload.tar.gz"
sha512sums="545818b3432aada2ae4f2df6f78e81bebd0efa471936646e312d284c4f1ec7866b644e25fa05ee6491610f4fc42de686a515a35da97082dfc22178d33928133c"

package() {
    install -dm755 "$pkgdir/home/root/xovi/exthome/appload"
    cp -r "$srcdir/$pkgname" "$pkgdir/home/root/xovi/exthome/appload/$pkgname"
}
